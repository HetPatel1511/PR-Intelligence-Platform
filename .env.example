# Root-level convenience copy. Each app also has its own .env.example.
# Copy to .env in each app directory and fill in real values.
#
#   cp apps/backend/.env.example  apps/backend/.env
#   cp apps/frontend/.env.example apps/frontend/.env

# ---- Backend ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pr_intelligence?schema=public"
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN_SECONDS=604800
TOKEN_ENCRYPTION_KEY=replace-with-another-long-random-string

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
GITHUB_SCOPES="read:user repo"

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:4000/api
