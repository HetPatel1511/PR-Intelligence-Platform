# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pr_intelligence?schema=public"

# HTTP server
PORT=4000
NODE_ENV=development

# URL of the frontend, used for CORS + OAuth redirects.
CLIENT_URL=http://localhost:5173

# --- Auth ---
# Secret for signing our session JWTs. Use a long random string.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
# Session JWT lifetime in seconds (optional; default 604800 = 7 days).
JWT_EXPIRES_IN_SECONDS=604800
# Passphrase used to encrypt GitHub access tokens at rest (AES-256-GCM).
TOKEN_ENCRYPTION_KEY=replace-with-another-long-random-string

# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps).
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
# OAuth scopes to request (optional; default shown). `repo` is needed to read PRs.
GITHUB_SCOPES="read:user repo"
